# Tests for 17041/a.rac

tests:
    - name: "Single filer, $28.5k taxable (base thresholds)"
      period: 1982-01
      inputs:
        ca_taxable_income: 28500
        filing_status: single
      # Tax = 3650*0.01 + 5000*0.02 + 5000*0.04 + 5300*0.06 + 5000*0.08 + 4550*0.093
      #     = 36.50 + 100 + 200 + 318 + 400 + 423.15 = 1477.65
      expect: 1478
    - name: "Joint filers, $47k taxable (base thresholds)"
      period: 1982-01
      inputs:
        ca_taxable_income: 47000
        filing_status: married_filing_jointly
      # Tax on $47,000 joint using base brackets
      expect: 1402
    - name: "Zero income"
      period: 1982-01
      inputs:
        ca_taxable_income: 0
        filing_status: single
      expect: 0
