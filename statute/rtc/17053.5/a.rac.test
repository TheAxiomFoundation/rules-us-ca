# Tests for 17053.5/a.rac

tests:
    - name: "Single renter under threshold"
      period: 2024-01
      inputs:
        ca_agi: 40000
        filing_status: single
        is_renter: true
      # Uses indexed 2024 threshold; base amount $60
      expect: 60
    - name: "Joint renter under threshold"
      period: 2024-01
      inputs:
        ca_agi: 80000
        filing_status: married_filing_jointly
        is_renter: true
      # Uses indexed 2024 threshold; base amount $120
      expect: 120
    - name: "Single over threshold - no credit"
      period: 2024-01
      inputs:
        ca_agi: 60000
        filing_status: single
        is_renter: true
      # Over base threshold ($25k)
      expect: 0
    - name: "Not a renter - no credit"
      period: 2024-01
      inputs:
        ca_agi: 20000
        filing_status: single
        is_renter: false
      expect: 0
