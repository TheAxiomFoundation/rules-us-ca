# California Revenue & Taxation Code Section 17054(c)
# Personal Exemption Credit - Age 65+
#
# Source: https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?sectionNum=17054.&lawCode=RTC

# (c) A credit of fifty-two dollars ($52) if the individual is 65 years of age
# or older on the last day of the taxable year.

ca_senior_exemption_base:
    from 1989-01-01: 52
