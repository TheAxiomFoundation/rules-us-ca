# California Revenue & Taxation Code Section 17054(e)
# Personal Exemption Credit - Blind Taxpayer
#
# Source: https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?sectionNum=17054.&lawCode=RTC

# (e) A credit for personal exemption of fifty-two dollars ($52) if the taxpayer
# is blind on the last day of the taxable year.

variable ca_blind_exemption_base:
    from 1989-01-01: 52
