# California Revenue & Taxation Code Section 17054(b)
# Personal Exemption Credit - Joint/Surviving Spouse
#
# Source: https://leginfo.legislature.ca.gov/faces/codes_displaySection.xhtml?sectionNum=17054.&lawCode=RTC

# (b) A credit of one hundred four dollars ($104) for a surviving spouse or for
# married persons filing a joint return.

variable ca_personal_exemption_joint_base:
    from 1989-01-01: 104
