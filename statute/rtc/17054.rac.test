# Tests for 17054.rac

tests:
    - name: "Single filer, no dependents"
      period: 1989-01
      inputs:
        filing_status: single
        age: 30
        n_dependents: 0
        is_blind: false
      # Base single credit = $52
      expect: 52
    - name: "Joint filers, senior, 2 dependents"
      period: 1989-01
      inputs:
        filing_status: married_filing_jointly
        age: 67
        n_dependents: 2
        is_blind: false
      # Joint $104 + senior $52 + 2x$227 = $610
      expect: 610
    - name: "Single, blind"
      period: 1989-01
      inputs:
        filing_status: single
        age: 40
        n_dependents: 0
        is_blind: true
      # Single $52 + blind $52 = $104
      expect: 104
